# Copy to ".env" and fill in values. Do not commit ".env".

# Volcengine Ark (OpenAI-compatible)
# 对话与嵌入默认共用 VOLCENGINE_API_KEY；若「在线推理」里为 embedding 接入点单独创建了 API Key，请填下面一项（否则可省略）。
VOLCENGINE_API_KEY=
# VOLCENGINE_EMBEDDING_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 对话大模型接入点（ep-...）
LLM_MODEL=

# Embeddings: volcengine = Ark POST /embeddings（豆包 doubao-embedding 接入点）; local = sentence-transformers（HF）
# EMBEDDING_BACKEND=volcengine
# 嵌入接入点（与 LLM_MODEL 可不同，各自一个 ep-...）
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSION：须与当前嵌入模型输出维度一致，否则 Chroma 写入会报错或检索异常。查找方式任选其一：
#   - 火山方舟控制台：该「向量化/嵌入」接入点或模型说明里的「向量维度 / 输出维度」；
#   - 火山引擎文档：对应 doubao-embedding 模型页的参数说明；
#   - 本地验证：用同一 KEY 调一次 embeddings 接口，看返回的 embedding 数组长度 len(...) 即为维度。
# 常见示例值（以你控制台为准，勿盲抄）：2560、1024 等。
# EMBEDDING_DIMENSION=2560
# 切换嵌入维度或模型时，请换新 CHROMADB_COLLECTION 或清空 backend/data/vector_db
# CHROMADB_COLLECTION=document_chunks

# Min cosine similarity (1 - Chroma distance) for a chunk to count as retrieved. Default 0.7.
# SIMILARITY_THRESHOLD=0.7

# Optional: pin Hugging Face cache for embedding models (sentence-transformers / Hub).
# Create this folder (or set a path); first online run downloads weights here; copy the folder for offline machines.
# Relative paths are resolved under the backend/ directory.
# EMBEDDING_CACHE_DIR=./data/models/hf_home

# Offline embedding / Hub: set true after cache is populated (no network for model download).
# TRANSFORMERS_OFFLINE=true
