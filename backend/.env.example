# Copy to ".env" and fill in values. Do not commit ".env".

# --- Chat LLM (OpenAI-compatible chat.completions) ---
# LLM_API_KEY=
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# --- Embeddings ---
# Default in config: EMBEDDING_BACKEND=local (sentence-transformers). For HTTP embeddings (same OpenAI-style API):
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-v3   # example; use your provider's model id
# EMBEDDING_DIMENSION=1024            # must match model output
# Optional separate key/URL for embeddings (otherwise LLM_API_KEY / LLM_BASE_URL are used):
# EMBEDDING_OPENAI_API_KEY=
# EMBEDDING_OPENAI_BASE_URL=
# Vision-style embedding APIs that use POST .../embeddings/multimodal:
# EMBEDDING_USE_MULTIMODAL_API=true
# EMBEDDING_DIMENSION: must match model (call API once and check len(embedding) if unsure).
# CHROMADB_COLLECTION=document_chunks
# SIMILARITY_THRESHOLD=0.7

# Optional: Hugging Face cache under backend/ (see config EMBEDDING_CACHE_DIR).
# EMBEDDING_CACHE_DIR=./data/models/hf_home
# TRANSFORMERS_OFFLINE=true

# --- Splite corpus: local BGE (Chinese) + dedicated Chroma collection ---
# Ingest script ``backend/scripts/ingest_merged_corpus_bge.py`` forces local BGE for the run;
# align these when querying that collection from the API:
# EMBEDDING_BACKEND=local
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# EMBEDDING_DIMENSION=1024
# CHROMADB_COLLECTION=splite_bge_zh_v15

# --- Hybrid RAG (graph + splite BGE vector in parallel, then LLM) ---
# RAG_BACKEND=hybrid
# HYBRID_SPLITE_COLLECTION=splite_bge_zh_v15
# HYBRID_SPLITE_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# HYBRID_VECTOR_TOP_K=5
# HYBRID_CONTEXT_MAX_CHARS=24000
# Requires: LLM_API_KEY, LLM_BASE_URL, LLM_MODEL; splite collection populated; graph API reachable.

# --- Ops: Splite corpus + BGE (local) ---
# 1) Merge JSON: backend\venv\Scripts\python.exe backend\scripts\merge_splite_json.py
# 2) Ingest: backend\venv\Scripts\python.exe backend\scripts\ingest_merged_corpus_bge.py --recreate
# 3) Optional: HF_TOKEN for Hub rate limits.
# 4) Chroma: backend\data\vector_db (gitignored).
# 5) Debug vector-only: POST /api/splite_search with same body as /api/search.
